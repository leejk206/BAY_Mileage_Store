{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "lib": ["es2021"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["tests/**/*.ts", "target/types/**/*.ts"],
  "exclude": ["node_modules", "web", "scripts"]
}
